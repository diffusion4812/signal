# CMake generated build files (out-of-source builds)
# It is recommended to use out-of-source builds with CMake
# e.g., "build", "out", "cmake-build-debug" directories
/out/
build/
[Cc]makeFiles/
CMakeCache.txt
*.cmake
# Specific to some build systems
CmakeScripts/
Testing/
_CPack_Packages/

# 1. Ignore the directory's contents, but not the directory itself
.vscode/*

# 2. Now you can allow specific files
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# 3. Ignore everything else inside (redundant but safe)
.vscode/.DS_Store

# Operating System generated files
.DS_Store # macOS
Thumbs.db # Windows

# --- Build Artifacts & Debug Symbols ---
*.pdb
*.tlog

# --- MSBuild / Visual Studio Project Metadata ---
# When using CMake, these are generated artifacts and should be ignored
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
