# CMake generated build files (out-of-source builds)
# It is recommended to use out-of-source builds with CMake
# e.g., "build", "out", "cmake-build-debug" directories
/build/
/out/
build/
[Cc]makeFiles/
CMakeCache.txt
*.cmake
# Specific to some build systems
CmakeScripts/
Testing/
_CPack_Packages/

# VS Code specific files
# .vscode/ folder is ignored by default except for a few recommended files
# which can be shared with the team (settings.json, launch.json, etc.)
.vscode/
# Ignore user-specific workspace files
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
# Ignore all other files in the .vscode folder
.vscode/*

# Operating System generated files
.DS_Store # macOS
Thumbs.db # Windows

# --- Build Artifacts & Debug Symbols ---
*.pdb
*.tlog

# --- MSBuild / Visual Studio Project Metadata ---
# When using CMake, these are generated artifacts and should be ignored
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
